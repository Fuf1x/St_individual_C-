<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="FufixDatabase"
			 connectionString="Host=localhost;Database=fufixland;Username=postgres;Password=postgres;"
			 providerName="Npgsql" />
	</connectionStrings>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
</configuration>